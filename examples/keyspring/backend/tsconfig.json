{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"types": ["bun-types"],
		"paths": {
			"@ika.xyz/plugins/sui/source": ["../../../sdk/plugins/src/sui/source/index.ts"],
			"@ika.xyz/plugins/ethereum/destination": [
				"../../../sdk/plugins/src/ethereum/destination/index.ts"
			],
			"@ika.xyz/plugins/ethereum/publisher": [
				"../../../sdk/plugins/src/ethereum/publisher/index.ts"
			]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
